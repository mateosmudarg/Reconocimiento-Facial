# Base de datos centralizada (PostgreSQL recomendado; MySQL soportado)
DATABASE_URL=postgresql+asyncpg://recfac:recfac@localhost:5432/recfac
# Para MySQL:
# DATABASE_URL=mysql+aiomysql://recfac:recfac@localhost:3306/recfac

# Seguridad / JWT
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Reconocimiento facial
# Umbral de similitud coseno para considerar coincidencia (0-1, mayor = mas estricto)
FACE_MATCH_THRESHOLD=0.45

# Credenciales del primer administrador (usadas por seed.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
