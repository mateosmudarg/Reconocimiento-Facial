# Dirección del servidor central (API FastAPI)
SERVER_URL=http://localhost:8000

# Identificador de este dispositivo/kiosko (aparece en el panel)
DEVICE_NAME=Entrada Principal

# Índice de la cámara (0 = cámara por defecto)
CAMERA_INDEX=0

# Modelo InsightFace (buffalo_l = preciso; buffalo_s = más liviano/rápido)
FACE_MODEL=buffalo_l
# Ejecución: CPU o CUDA si hay GPU disponible
FACE_PROVIDER=CPUExecutionProvider

# Control de puerta vía Arduino (opcional). Vacío = desactivado.
ARDUINO_PORT=
ARDUINO_BAUD=9600
